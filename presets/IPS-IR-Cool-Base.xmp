   <crs:Name>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">IPS — IR Cool Base</rdf:li>
    </rdf:Alt>
   </crs:Name>
   <crs:ShortName>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">IR Cool Base</rdf:li>
    </rdf:Alt>
