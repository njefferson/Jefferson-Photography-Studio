      "subject_phrase": "a low bank of ground fog",
      "meta_label": "Ground fog",
      "poses": [
        {
          "pose": "rolling",
          "pose_phrase": "a low rolling band of fog"
        }
      ]
    },
    {
      "family": "smoke",
      "subject_phrase": "a column of drifting grey smoke",
      "meta_label": "Smoke",
      "poses": [
        {
          "pose": "rising",
          "pose_phrase": "rising and curling"
        }
      ]
    },
    {
      "family": "steam",
      "subject_phrase": "a plume of white steam",
