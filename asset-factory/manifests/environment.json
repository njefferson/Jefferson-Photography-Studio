  "families": [
    { "family": "footprint", "subject_phrase": "a single large fresh footprint pressed into mud", "meta_label": "Footprint", "qc": { "allowEdgeContact": true }, "poses": [{ "pose": "in-mud", "pose_phrase": "a crisp deep impression", "views": ["above"] }] },
    { "family": "old-footprint", "subject_phrase": "an old weathered footprint impression, partly eroded", "meta_label": "Old footprint", "qc": { "allowEdgeContact": true }, "poses": [{ "pose": "in-dirt", "pose_phrase": "a faint aged impression", "views": ["above"] }] },
    { "family": "hair-sample", "subject_phrase": "a small tuft of coarse unidentified animal hair", "meta_label": "Hair sample", "poses": [{ "pose": "tuft", "pose_phrase": "a caught tuft of hair", "distances": ["close"] }] },
