    { "family": "backpack", "subject_phrase": "a weathered abandoned hiking backpack", "meta_label": "Abandoned backpack", "poses": [{ "pose": "resting", "pose_phrase": "slumped and empty" }] },
    { "family": "tent", "subject_phrase": "a small weathered dome camping tent", "meta_label": "Tent", "poses": [{ "pose": "pitched", "pose_phrase": "pitched, flap open" }] },
