    { "family": "crop-damage", "subject_phrase": "a patch of flattened swirled crop stalks", "meta_label": "Crop damage", "qc": { "allowEdgeContact": true }, "poses": [{ "pose": "flattened", "pose_phrase": "swirled and pressed flat", "views": ["above"] }] },
